{
	"name": "@proagentstore/browser-runner",
	"version": "0.2.0",
	"private": true,
	"description": "FreeAgentStore browser runtime executor for ProAgentStore browser tasks",
	"license": "MIT",
	"type": "module",
	"bin": {
		"pags-browser-runner": "dist/index.js",
		"pags-test-job-server": "dist/test-job-server-cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"homepage": "https://github.com/ProAgentStore/platform#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ProAgentStore/platform.git",
		"directory": "packages/browser-runner"
	},
	"keywords": [
		"proagentstore",
		"pags",
		"browser-runner",
		"playwright",
		"agents"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"dev:test-job-server": "tsx src/test-job-server-cli.ts",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"playwright": "^1.60.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.4"
	},
	"sideEffects": false
}
