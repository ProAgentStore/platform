{
	"name": "@proagentstore/cli",
	"version": "0.1.0",
	"description": "CLI for creating and publishing ProAgentStore agents",
	"license": "MIT",
	"type": "module",
	"bin": {
		"pags": "dist/index.js"
	},
	"homepage": "https://github.com/ProAgentStore/platform#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ProAgentStore/platform.git",
		"directory": "packages/cli"
	},
	"keywords": [
		"proagentstore",
		"pags",
		"cli",
		"agents",
		"browser-runner"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsx src/index.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^13.0.0"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0",
		"@types/node": "^22.0.0"
	},
	"files": [
		"dist"
	]
}
