{
  "name": "@proagentstore/cli",
  "version": "0.4.15",
  "description": "CLI for creating, publishing, and running ProAgentStore agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pags": "dist/index.js"
  },
  "homepage": "https://github.com/ProAgentStore/platform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProAgentStore/platform.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "proagentstore",
    "pags",
    "cli",
    "agents",
    "mcp",
    "browser-runner"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --filter @proagentstore/browser-runner build && tsup src/index.ts --format esm --dts && node scripts/copy-browser-runner.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/mcp": "0.0.77",
    "chalk": "^5.6.2",
    "commander": "^13.0.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ]
}
