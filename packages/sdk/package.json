{
	"name": "@proagentstore/sdk",
	"version": "0.1.0",
	"private": true,
	"description": "SDK for server-powered AI agents on proagentstore.online — Workers AI, D1, R2, Stripe Connect, cron, API gateway.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		},
		"./ui": {
			"types": "./dist/ui.d.ts",
			"import": "./dist/ui.js"
		},
		"./hooks": {
			"types": "./dist/hooks.d.ts",
			"import": "./dist/hooks.js"
		}
	},
	"homepage": "https://github.com/ProAgentStore/platform#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ProAgentStore/platform.git",
		"directory": "packages/sdk"
	},
	"keywords": [
		"proagentstore",
		"sdk",
		"ai",
		"workers-ai",
		"d1",
		"r2",
		"stripe",
		"agents"
	],
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.2.0",
		"typescript": "^5.7.0"
	},
	"sideEffects": false
}
